# ===== Server Configuration =====
# Copy this file to .env and fill in real values. Never commit the real .env file.

# Port the Express server listens on (Render sets this automatically — you usually don't need to set it there)
PORT=5001

# JWT signing secret — use a long random string in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret

# Google OAuth Client ID (from Google Cloud Console > Credentials). Leave the mock value for demo/testing.
GOOGLE_CLIENT_ID=mock_google_client_id_for_shelf_life_system

# The deployed frontend URL (Vercel), required for CORS in production.
# Example: https://shelf-life-reminder.vercel.app
FRONTEND_URL=

# ===== Database Configuration (MySQL) =====
# Render does not offer managed MySQL. Use an external MySQL provider (e.g. Aiven, PlanetScale-compatible
# host, Railway, Clever Cloud) or a self-hosted MySQL instance, and put its credentials below.
# If these are left as localhost defaults (or the DB is unreachable), the app automatically falls back
# to an in-memory mock database so it still runs — but data will not persist across restarts/deploys.
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=shelf_life_db
DB_PORT=3306
