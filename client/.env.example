# ===== Client Configuration =====
# Copy this file to .env for local development. Never commit the real .env file.

# Local development (Express backend runs on port 5001 by default)
VITE_API_URL=http://localhost:5001/api

# In Vercel project settings (Settings > Environment Variables), set VITE_API_URL to your
# deployed Render backend URL instead, e.g.:
# VITE_API_URL=https://shelf-life-api.onrender.com/api

VITE_GOOGLE_CLIENT_ID=mock_google_client_id_for_shelf_life_system
